FROM docker.io/library/python

# Install system dependencies for headless rendering with Blender
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ffmpeg \
    libegl1 \
    libegl-mesa0 \
    libgl1 \
    libgl1-mesa-dri \
    libheif1 \
    libosmesa6-dev \
    xauth \
    xvfb \
    blender \
    python3-numpy \
    && rm -rf /var/lib/apt/lists/*

ARG STL_THUMB_VERSION=v0.5.0
RUN arch="$(dpkg --print-architecture)" \
     && curl -fL "https://github.com/unlimitedbacon/stl-thumb/releases/download/${STL_THUMB_VERSION}/stl-thumb_${STL_THUMB_VERSION#v}_${arch}.deb" \
         -o /tmp/stl-thumb.deb \
     && apt-get update \
     && apt-get install -y --no-install-recommends /tmp/stl-thumb.deb \
     && rm -f /tmp/stl-thumb.deb \
     && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir Pillow python-dotenv pi-heif

WORKDIR /usr/src/app
COPY gallery.py .
COPY blender_thumb.py .
COPY matcap.png .

ENV GALLERY_HOST=0.0.0.0
ENV GALLERY_PORT=8000
ENV GALLERY_DIRECTORY=/gallery
ENV THUMBNAIL_DIRECTORY=/thm
EXPOSE 8000
VOLUME [ "/gallery" ]
VOLUME [ "/thm" ]
CMD [ "python", "./gallery.py" ]
